# Yandex Cloud OAuth token (получить: yc iam create-token)
yc_token = "your_yandex_cloud_token"

# Cloud и Folder ID (получить: yc config list)
cloud_id  = "your_cloud_id"
folder_id = "your_folder_id"

# Зона доступности
zone = "ru-central1-a"

# Размер VM
vm_cores  = 2
vm_memory = 2

# SSH ключи
ssh_public_key_path  = "~/.ssh/id_ed25519.pub"
ssh_private_key_path = "~/.ssh/id_ed25519"

# Домен (опционально)
domain = ""
